{
  "name": "rosetta-squint",
  "version": "0.1.0",
  "description": "Cross-language byte-exact perceptual image hashing — decode + hash in one call",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "engines": { "node": ">=18" },
  "license": "BSD-2-Clause",
  "bin": {
    "squint-cli": "./scripts/squint-cli.mjs"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "rosetta-image-decode": "file:../../../decode/js/rosetta-image-decode",
    "rosetta-image-hash": "file:../../../hash/js/rosetta-image-hash",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/webp": "^1.5.0",
    "libheif-js": "1.17.1",
    "pngjs": "^7",
    "utif2": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5",
    "vitest": "^2",
    "@types/node": "^20"
  }
}
