{
  "name": "rosetta-image-decode",
  "version": "0.1.0",
  "description": "Byte-exact PIL-compatible image decoder library (JS/TS)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "BSD-2-Clause",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "omggif": "^1.0",
    "pngjs": "^7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/omggif": "^1",
    "@types/pngjs": "^6",
    "typescript": "^5.5",
    "vitest": "^2"
  }
}
